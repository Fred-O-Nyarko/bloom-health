# ─── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ─── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to use for the agent (default: Rachel — warm, calm)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Leave EMPTY on first run — the app will auto-create the agent
# and print the generated Agent ID for you to paste here.
ELEVENLABS_AGENT_ID=

# ─── Server ───────────────────────────────────────────────
# Your public URL (ngrok, Cloudflare Tunnel, etc.)
# Twilio CANNOT reach localhost — this must be publicly accessible
# Example: https://a1b2-123-45-67-89.ngrok-free.app
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app
